    "notes": "Contractor receives shop drawings and gives a quick glance before submitting."
  },
  {
    "uid": 17,
    "id": 21,
    "name": "Expedited GC Review",
    "wbs": "3.6",
    "outlineLevel": 2,
    "start": "2026-07-10T08:00:00",
    "finish": "2026-07-10T17:00:00",
    "durationMinutes": 480,
    "durationWorkingDays": 1,
    "isMilestone": false,
